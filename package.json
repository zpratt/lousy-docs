{
    "name": "lousy-docs",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "prebuild": "bash scripts/fetch-docs.sh",
        "build": "npm run prebuild && astro build",
        "dev": "bash scripts/fetch-docs.sh && astro dev --host 0.0.0.0",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "lint:workflows": "actionlint",
        "lint:yaml": "yamllint .",
        "preview": "astro preview",
        "test": "vitest run",
        "test:e2e": "playwright test",
        "test:e2e:dist": "npm run build && TEST_PREVIEW=true playwright test",
        "test:e2e:ui": "playwright test --ui"
    },
    "dependencies": {
        "@astrojs/react": "5.0.3",
        "@astrojs/sitemap": "3.7.2",
        "antd": "6.3.5",
        "astro": "6.1.5",
        "astro-pagefind": "1.8.6",
        "pino": "10.3.1",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.10",
        "@lousy-agents/mcp": "5.9.3",
        "@modelcontextprotocol/server-sequential-thinking": "2025.12.18",
        "@playwright/mcp": "0.0.70",
        "@playwright/test": "1.59.1",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@testing-library/user-event": "14.6.1",
        "@types/chance": "1.1.7",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@upstash/context7-mcp": "2.1.7",
        "@vitejs/plugin-react": "6.0.1",
        "@vitest/ui": "4.1.4",
        "chance": "1.1.13",
        "happy-dom": "20.8.9",
        "jsdom": "29.0.2",
        "msw": "2.13.2",
        "typescript": "6.0.2",
        "vitest": "4.1.4",
        "whatwg-fetch": "3.6.20",
        "wrangler": "4.81.0"
    }
}
