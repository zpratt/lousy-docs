{
    "name": "lousy-docs",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04@sha256:d94c97dd9cacf183d0a6fd12a8e87b526e9e928307674ae9c94139139c0c6eae",
    "features": {
        "ghcr.io/devcontainers/features/node:1.7.1": {
            "version": "24.14.1"
        },
        "ghcr.io/devcontainers/features/github-cli:1.1.0": {
            "version": "latest"
        },
        "ghcr.io/devcontainers/features/copilot-cli:1.0.0": {},
        "ghcr.io/anthropics/devcontainer-features/claude-code:1": {
            "version": "v2.1.97"
        },
        "ghcr.io/rocker-org/devcontainer-features/apt-packages:1.0.2": {
            "packages": "libnss3, libnspr4, libatk1.0-0t64, libatk-bridge2.0-0t64, libcups2t64, libdrm2, libdbus-1-3, libatspi2.0-0t64, libxcomposite1, libxdamage1, libxfixes3, libxrandr2, libgbm1, libxkbcommon0, libasound2t64, yamllint, shellcheck",
            "upgradePackages": false
        },
        "ghcr.io/devcontainers-extra/features/actionlint:1.1.1": {
            "version": "1.7.12"
        }
    },
    "forwardPorts": [3000],
    "portsAttributes": {
        "3000": {
            "label": "Application",
            "onAutoForward": "notify"
        }
    },
    "postCreateCommand": "npm i -g @lousy-agents/agent-shell && npm i",
    "waitFor": "postCreateCommand",
    "remoteUser": "vscode",
    "customizations": {
        "vscode": {
            "extensions": [
                "biomejs.biome",
                "anthropic.claude-code",
                "editorconfig.editorconfig",
                "vitest.explorer",
                "ms-vscode-remote.remote-containers",
                "GitHub.codespaces",
                "GitHub.copilot-chat",
                "GitHub.github-vscode-theme",
                "redhat.vscode-yaml"
            ],
            "settings": {
                "editor.formatOnSave": true,
                "editor.defaultFormatter": "biomejs.biome",
                "[json]": {
                    "editor.defaultFormatter": "biomejs.biome"
                },
                "[javascript]": {
                    "editor.defaultFormatter": "biomejs.biome"
                },
                "[typescript]": {
                    "editor.defaultFormatter": "biomejs.biome"
                },
                "[yaml]": {
                    "editor.defaultFormatter": "redhat.vscode-yaml",
                    "editor.tabSize": 2
                },
                "vitest.enable": true,
                "vitest.commandLine": "vitest",
                "github.copilot.chat.agent.model": "claude-sonnet-4.6",
                "github.copilot.chat.ask.model": "claude-sonnet-4.6",
                "yaml.schemas": {
                    "https://json.schemastore.org/github-workflow.json": ".github/workflows/*.yml"
                },
                "github.copilot.chat.mcp.enabled": true,
                "terminal.integrated.defaultProfile.linux": "bash"
            },
            "mcp": {
                "servers": {
                    "context7": {
                        "type": "stdio",
                        "command": "npx",
                        "args": ["@upstash/context7-mcp"]
                    },
                    "sequential-thinking": {
                        "command": "npx",
                        "args": [
                            "@modelcontextprotocol/server-sequential-thinking"
                        ]
                    }
                }
            }
        }
    }
}
