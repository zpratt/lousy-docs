---
// biome-ignore lint/correctness/noUnusedImports: used in Astro HTML template
import Search from "astro-pagefind/components/Search";
import "../styles/global.css";

interface Props {
    title: string;
    description?: string;
    pagefindIgnore?: boolean;
}

// biome-ignore lint/correctness/noUnusedVariables: used in Astro HTML template
const title = Astro.props.title;
// biome-ignore lint/correctness/noUnusedVariables: used in Astro HTML template
const description =
    Astro.props.description ?? "Documentation for the Lousy Agents ecosystem.";
// biome-ignore lint/correctness/noUnusedVariables: used in Astro HTML template
const pagefindIgnore = Astro.props.pagefindIgnore ?? false;

// biome-ignore lint/correctness/noUnusedVariables: used in Astro HTML template
const cfBeaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN;
// biome-ignore lint/correctness/noUnusedVariables: used in Astro HTML template
const googleSiteVerificationToken = import.meta.env
    .PUBLIC_GOOGLE_SITE_VERIFICATION_TOKEN;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        {googleSiteVerificationToken && (
            <meta
                name="google-site-verification"
                content={googleSiteVerificationToken}
            />
        )}
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link
            rel="preconnect"
            href="https://fonts.gstatic.com"
            crossorigin=""
        />
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Manrope:wght@400;500;600;700&display=swap"
        />
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        />
        <title>{title}</title>
    </head>
    <body>
        <div id="main-content" data-pagefind-ignore={pagefindIgnore ? "all" : undefined}>
            <slot />
        </div>
        <div
            id="search-overlay"
            class="search-overlay"
            data-pagefind-ignore="all"
        >
            <div class="search-overlay__backdrop"></div>
            <div class="search-overlay__panel" role="dialog" aria-modal="true" aria-label="Search documentation">
                <button
                    type="button"
                    class="search-overlay__close"
                    aria-label="Close search"
                >
                    <span class="material-symbols-outlined" aria-hidden="true">close</span>
                </button>
                <Search
                    id="search"
                    className="pagefind-ui analog-terminal"
                    uiOptions={{
                        showSubResults: true,
                        showImages: false,
                        resetStyles: false,
                    }}
                />
            </div>
        </div>
        <script is:inline>
            (function () {
                const overlay = document.getElementById("search-overlay");
                const panel = overlay && overlay.querySelector(".search-overlay__panel");
                const closeBtn = overlay && overlay.querySelector(".search-overlay__close");
                const mainContent = document.getElementById("main-content");
                let previouslyFocused = null;

                function openSearch() {
                    if (!overlay) return;
                    previouslyFocused = document.activeElement;
                    overlay.classList.add("search-overlay--open");
                    document.body.style.overflow = "hidden";
                    if (mainContent) mainContent.inert = true;
                    const input = overlay.querySelector(".pagefind-ui__search-input");
                    if (input) {
                        input.focus();
                        input.select();
                    } else if (closeBtn) {
                        closeBtn.focus();
                    }
                }

                function closeSearch() {
                    if (!overlay) return;
                    overlay.classList.remove("search-overlay--open");
                    document.body.style.overflow = "";
                    if (mainContent) mainContent.inert = false;
                    if (previouslyFocused && typeof previouslyFocused.focus === "function") {
                        previouslyFocused.focus();
                    }
                    previouslyFocused = null;
                }

                function isSearchOpen() {
                    return overlay && overlay.classList.contains("search-overlay--open");
                }

                function trapFocus(e) {
                    if (!panel || !isSearchOpen()) return;
                    const focusable = panel.querySelectorAll(
                        'a[href], button:not([disabled]), input:not([disabled]), textarea:not([disabled]), select:not([disabled]), [tabindex]:not([tabindex="-1"])'
                    );
                    if (focusable.length === 0) return;
                    const first = focusable[0];
                    const last = focusable[focusable.length - 1];
                    if (e.shiftKey && document.activeElement === first) {
                        e.preventDefault();
                        last.focus();
                    } else if (!e.shiftKey && document.activeElement === last) {
                        e.preventDefault();
                        first.focus();
                    }
                }

                window.addEventListener("open-search", openSearch);

                if (closeBtn) {
                    closeBtn.addEventListener("click", closeSearch);
                }

                if (overlay) {
                    overlay.addEventListener("click", function (e) {
                        if (panel && e.target instanceof Node && !panel.contains(e.target)) {
                            closeSearch();
                        }
                    });
                }

                document.addEventListener("keydown", function (e) {
                    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
                        e.preventDefault();
                        if (isSearchOpen()) {
                            closeSearch();
                        } else {
                            openSearch();
                        }
                    }
                    if (e.key === "Escape" && isSearchOpen()) {
                        closeSearch();
                    }
                    if (e.key === "Tab" && isSearchOpen()) {
                        trapFocus(e);
                    }
                });
            })();
        </script>
        <script is:inline>
            document.addEventListener("DOMContentLoaded", function () {
                const script = document.createElement("script");
                script.type = "module";
                script.src = "/pagefind/pagefind-highlight.js";
                script.onload = function () {
                    try {
                        new window.PagefindHighlight({ highlightParam: "highlight" });
                    } catch (e) {
                        console.debug("[pagefind-highlight] Initialization failed:", e);
                    }
                };
                script.onerror = function () {
                    console.debug("[pagefind-highlight] Script not found (expected before first build)");
                };
                document.head.appendChild(script);
            });
        </script>
        {cfBeaconToken && (
            <script
                defer
                src="https://static.cloudflareinsights.com/beacon.min.js"
                data-cf-beacon={JSON.stringify({ token: cfBeaconToken })}
            ></script>
        )}
    </body>
</html>
